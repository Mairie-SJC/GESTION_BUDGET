{% extends 'base.html.twig' %}

{% block title %}Budget{% endblock %}

{% block body %}
    <h1>Budget</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ budget.id }}</td>
            </tr>
            <tr>
                <th>Annee</th>
                <td>{{ budget.annee }}</td>
            </tr>
            <tr>
                <th>CodeComptable</th>
                <td>{{ budget.codeComptable }}</td>
            </tr>
            <tr>
                <th>LibelleLigne</th>
                <td>{{ budget.libelleLigne }}</td>
            </tr>
            <tr>
                <th>MontantAlloue</th>
                <td>{{ budget.montantAlloue }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_budget_index') }}">back to list</a>

    <a href="{{ path('app_budget_edit', {'id': budget.id}) }}">edit</a>

    {{ include('budget/_delete_form.html.twig') }}
{% endblock %}
