{% extends 'base.html.twig' %}

{% block title %}Nouvelle Facture - Budget SI{% endblock %}

{% block body %}
<div style="max-width: 600px; margin: 20px auto;">
    
    <div style="margin-bottom: 20px;">
        <a href="{{ path('app_dashboard') }}">⬅ Retour au tableau de bord</a>
    </div>

    <div class="sjc-card" style="border-left-color: var(--sjc-primaire);">
        <h2>🧾 Saisir une nouvelle facture</h2>
        <br>

        {{ form_start(formulaire) }}
            
            {{ form_widget(formulaire) }}
            
            <button type="submit" style="margin-top: 20px; background-color: #2c3e50; color: white; padding: 10px 15px; border: none; border-radius: 4px; cursor: pointer; width: 100%;">
                Enregistrer la facture
            </button>
            
        {{ form_end(formulaire) }}
    </div>
</div>
{% endblock %}